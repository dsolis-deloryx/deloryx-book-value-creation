%% ----- Metric card: dense KPI reference (name + formula in title; \mcfield rows) -----
%% Usage:
%%   \begin{metriccard}{ROAS}{\text{Revenue}/\text{Ad Spend}}
%%     \mcfield{Tells you}{Revenue per dollar of media spend}
%%     \mcfield{Benchmark}{3--8$\times$ e-commerce; 1--2$\times$ brand}
%%     \mcfield{Trap}{Blended ROAS hides branded-search subsidy}
%%   \end{metriccard}
%% Group two-up inside \begin{multicols}{2} ... \end{multicols}.
%% Optional first arg overrides styling (e.g. red frame for a vanity-metric card):
%%   \begin{metriccard}[colframe=red!60!black,colbacktitle=red!60!black]{Email open rate}{...}
\newtcolorbox{metriccard}[3][]{conceptbox, breakable=false,
  colframe=yellow!35!orange!85!black, colbacktitle=yellow!35!orange!85!black,
  title={\textbf{#2}\quad\normalfont\footnotesize\ensuremath{#3}},
  fontupper=\small, left=1.5mm, right=1.5mm, top=0.5mm, bottom=0.5mm,
  before upper={\setlist{nosep,leftmargin=*,itemsep=0pt,topsep=0pt}},
  #1}
\newcommand{\mcfield}[2]{\noindent{\bfseries\sffamily\footnotesize #1:\enspace}\ignorespaces#2\par\smallskip}

